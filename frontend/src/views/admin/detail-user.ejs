<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>

</head>
<body class="bg-light">
    <div class="app-wrapper">
        <%- include('partials/sidebar', { page: 'users' }) %>

        <main class="main-content">
            <%- include('partials/top-navbar', { pageTitle: 'Detail Pemohon' }) %>

            <div class="content-body">
                <!-- Alert Message -->
                <div id="alertMessage" class="alert alert-dismissible fade show" style="display: none;"></div>

                <!-- Navigation -->
                <div class="mb-4">
                    <a href="/admin/users" class="text-decoration-none text-muted">
                        <i class="fas fa-arrow-left me-2"></i>Kembali ke Daftar Pemohon
                    </a>
                </div>

        <!-- Profile Card -->
        <div class="profile-card" id="profileCard">
            <!-- Akan diisi JavaScript -->
        </div>

        <!-- Stats Row -->
        <div class="row g-3 mb-4" id="statsRow">
            <!-- Akan diisi JavaScript -->
        </div>

        <!-- Submissions Table -->
        <div class="profile-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0">Riwayat Pengajuan</h5>
                <span class="text-muted small" id="submissionCount"></span>
            </div>
            
            <div class="table-responsive">
                <table class="table-submissions">
                    <thead>
                        <tr>
                            <th>No. Registrasi</th>
                            <th>Jenis Uji</th>
                            <th>Jenis Sample</th>
                            <th>Nama Proyek</th>
                            <th>Tanggal</th>
                            <th>Status</th>
                            <th>Total</th>
                            <th class="text-center">Aksi</th>
                        </tr>
                    </thead>
                    <tbody id="submissionsTableBody">
                        <tr>
                            <td colspan="8" class="text-center py-4">
                                <div class="spinner-border spinner-border-sm text-primary me-2"></div>
                                Memuat data...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

                <!-- Pagination -->
                <div class="d-flex justify-content-between align-items-center mt-4">
                    <small class="text-muted" id="paginationInfo"></small>
                    <nav>
                        <ul class="pagination pagination-sm mb-0" id="pagination">
                            <!-- Akan diisi JavaScript -->
                        </ul>
                    </nav>
                </div>
            </div>
            </div>
        </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom JS -->
    <script src="/js/admin/detail-user.js"></script>
</body>
</html>