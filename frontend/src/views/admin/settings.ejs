        // Simpan semua perubahan mode sibuk
        // Simpan semua perubahan mode sibuk
        async function simpanModeSibuk() {
            try {
                // Tampilkan loading indicator (opsional)
                const saveBtn = event.target;
                const originalText = saveBtn.innerHTML;
                saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Menyimpan...';
                saveBtn.disabled = true;
                
                const response = await fetch(`${API_BASE_URL}/settings/busy-mode`, {
                    method: 'PUT',
                    headers: getAuthHeaders(), // Ini sudah pakai token
                    body: JSON.stringify({
                        active: busyModeActive
                    })
                });
                
                // Handle 401 Unauthorized
                if (response.status === 401) {
                    console.log('Token expired atau tidak valid');
                    
                    // Coba refresh token atau redirect ke login
                    const refreshResult = await tryRefreshToken();
                    
                    if (refreshResult) {
                        // Jika refresh berhasil, coba lagi
                        return simpanModeSibuk();
                    } else {
                        handleUnauthorized();
                        return;
                    }
                }
                
                const result = await response.json();
                
                if (result.success) {
                    showAlert('Mode sibuk berhasil disimpan', 'success');
                    
                    // Simpan juga ke localStorage sebagai cadangan
                    const data = {
                        active: busyModeActive,
                        periods: busyPeriods
                    };
                    localStorage.setItem('busyMode', JSON.stringify(data));
                } else {
                    showAlert(result.message || 'Gagal menyimpan mode sibuk', 'danger');
                }
                
            } catch (error) {
                console.error('Error saving busy mode:', error);
                showAlert('Gagal menyimpan mode sibuk', 'danger');
            } finally {
                // Kembalikan tombol ke normal
                const saveBtn = event.target;
                saveBtn.innerHTML = 'Simpan Perubahan';
                saveBtn.disabled = false;
            }
        }

        // Fungsi untuk mencoba refresh token
        async function tryRefreshToken() {
            try {
                const refreshToken = localStorage.getItem('refresh_token');
                if (!refreshToken) return false;
                
                const response = await fetch(`${API_BASE_URL}/auth/refresh-token`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ refresh_token: refreshToken })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    localStorage.setItem('admin_token', result.data.token);
                    if (result.data.refresh_token) {
                        localStorage.setItem('refresh_token', result.data.refresh_token);
                    }
                    return true;
                }
                return false;
            } catch (error) {
                console.error('Refresh token error:', error);
                return false;
            }
        }

        // Helper untuk format date input
        function formatDateForInput(date) {
            return date.toISOString().split('T')[0];
        }

        // ==================== CEK TOKEN ====================
        function getToken() {
            return localStorage.getItem('admin_token');
        }

        function handleUnauthorized() {
            // Simpan state sebelum redirect
            const currentPath = window.location.pathname + window.location.hash;
            sessionStorage.setItem('redirectAfterLogin', currentPath);
            
            // Simpan data mode sibuk ke localStorage sebelum logout
            const busyData = {
                active: busyModeActive,
                periods: busyPeriods
            };
            localStorage.setItem('busyMode_backup', JSON.stringify(busyData));
            
            // Hapus token
            localStorage.removeItem('admin_token');
            localStorage.removeItem('refresh_token');
            
            // Redirect ke login
            window.location.href = '/admin/login';
        }

        // Cek token sebelum load data
        const token = getToken();
        if (!token) {
            console.log('Token tidak ditemukan, redirect ke login');
            window.location.href = '/admin/login';
        }

        // Fungsi untuk mendapatkan headers dengan token
        function getAuthHeaders() {
            return {
                'Authorization': `Bearer ${token}`,
                'Content-Type': 'application/json'
            };
        }

        // ==================== LOAD SETTINGS ====================
        async function loadSettings() {
            try {
                // Load admin profile
                const profileResponse = await fetch(`${API_BASE_URL}/settings/profile`, {
                    headers: { 'Authorization': `Bearer ${getToken()}` }
                });
                
                if (profileResponse.status === 401) {
                    // Coba restore dari localStorage
                    restoreFromLocalStorage();
                    handleUnauthorized();
                    return;
                }

                const profileResult = await profileResponse.json();
                
                if (profileResult.success) {
                    adminData = profileResult.data;
                    updateProfileForm(adminData);
                }

                // Load system config
                const configResponse = await fetch(`${API_BASE_URL}/settings/system`, {
                    headers: { 'Authorization': `Bearer ${getToken()}` }
                });

                const configResult = await configResponse.json();
                
                if (configResult.success) {
                    systemConfig = configResult.data;
                    updateSystemForm(systemConfig);
                }

                // Load mode sibuk
                await loadBusyMode();

                // Load active sessions
                loadActiveSessions();

                // Load activity logs
                loadActivityLogs();

                // Load backup history
                loadBackupHistory();

            } catch (error) {
                console.error('Error:', error);
                
                // Jika error karena auth, coba restore dari localStorage
                if (error.message.includes('401') || error.message.includes('Unauthorized')) {
                    restoreFromLocalStorage();
                    handleUnauthorized();
                } else {
                    showAlert('Gagal memuat pengaturan', 'danger');
                }
            }
        }

        // Fungsi untuk restore dari localStorage
        function restoreFromLocalStorage() {
            // Coba restore mode sibuk dari backup
            const backup = localStorage.getItem('busyMode_backup');
            if (backup) {
                try {
                    const data = JSON.parse(backup);
                    busyModeActive = data.active || false;
                    busyPeriods = data.periods || [];
                    
                    // Update UI
                    document.getElementById('busyModeToggle').checked = busyModeActive;
                    document.getElementById('busyPeriodContainer').style.display = busyModeActive ? 'block' : 'none';
                    renderBusyPeriods();
                    
                    showAlert('Data dipulihkan dari penyimpanan lokal', 'info');
                } catch (e) {
                    console.error('Error restoring from localStorage:', e);
                }
            }
        }

