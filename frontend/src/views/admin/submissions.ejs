<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <style>
        /* Skeleton loading styles */
        .skeleton-loader {
            animation: skeleton-loading 1s linear infinite alternate;
        }
        
        @keyframes skeleton-loading {
            0% { background-color: #e0e0e0; }
            100% { background-color: #f0f0f0; }
        }
        
        .skeleton-text {
            height: 1.2rem;
            border-radius: 0.25rem;
        }
        
        .filter-badge {
            cursor: pointer;
            transition: all 0.2s;
        }
        
        .filter-badge:hover {
            transform: translateY(-2px);
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        
        .filter-badge.active {
            background-color: var(--primary) !important;
            color: white !important;
        }
        
        /* Status badge styles */
        .badge-soft-warning {
            background-color: #fff3cd;
            color: #856404;
        }
        .badge-soft-danger {
            background-color: #f8d7da;
            color: #721c24;
        }
        .badge-soft-success {
            background-color: #d4edda;
            color: #155724;
        }
        .badge-soft-primary {
            background-color: #cce5ff;
            color: #004085;
        }
        .badge-soft-info {
            background-color: #d1ecf1;
            color: #0c5460;
        }
        .badge-soft-secondary {
            background-color: #e2e3e5;
            color: #383d41;
        }
        
        /* Alert styles */
        .alert {
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .alert-danger {
            background-color: #fef2f2;
            border: 1px solid #fee2e2;
            color: #991b1b;
        }
        .alert-warning {
            background-color: #fffbeb;
            border: 1px solid #fef3c7;
            color: #92400e;
        }
        .alert-success {
            background-color: #f0fdf4;
            border: 1px solid #dcfce7;
            color: #166534;
        }
    </style>
</head>
<body>

    <%- include('partials/sidebar', { page: 'submissions' }) %>

    <div class="main-content">
        <%- include('partials/header', { title: 'Manajemen Pengajuan' }) %>

        <!-- Data dari backend disimpan di atribut data -->
        <div id="page-data" 
             data-submissions='<%- JSON.stringify(submissions || []).replace(/'/g, "\\'") %>'
             data-pagination='<%- JSON.stringify(pagination || {}).replace(/'/g, "\\'") %>'
             data-filters='<%- JSON.stringify(filters || {}).replace(/'/g, "\\'") %>'
             style="display: none;"></div>

        <!-- Alert Message -->
        <div id="alertMessage" class="alert" style="display: none;"></div>

        <div class="mb-4">
            <h5 class="fw-bold">Daftar Pengajuan Masuk</h5>
            <p class="text-muted">Kelola dan pantau status pengajuan pengujian laboratorium.</p>
        </div>

        <!-- Filter dan Search Section -->
        <div class="card-custom mb-4">
            <div class="row g-3 align-items-center">
                <!-- Search -->
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0 text-muted ps-3">
                            <i class="fas fa-search"></i>
                        </span>
                        <input type="text" class="form-control bg-light border-0 shadow-none" id="searchInput" placeholder="Cari ID Pengajuan, Perusahaan, atau PIC...">
                    </div>
                </div>
                
                <!-- Filter Tanggal (di tengah) -->
                <div class="col-md-4">
                    <div class="d-flex gap-2 align-items-center">
                        <div class="flex-fill">
                            <input type="date" class="form-control bg-light border-0 shadow-none" 
                                id="startDateFilter" placeholder="Periode Awal" onchange="applyFilter()">
                        </div>
                        <span class="text-muted">-</span>
                        <div class="flex-fill">
                            <input type="date" class="form-control bg-light border-0 shadow-none" 
                                id="endDateFilter" placeholder="Periode Akhir" onchange="applyFilter()">
                        </div>
                        <button class="btn btn-outline-secondary btn-sm" onclick="resetDateFilter()" title="Reset Tanggal">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                </div>
                
                <!-- Filter Status, Kategori, dan Sort -->
                <div class="col-md-4">
                    <div class="d-flex justify-content-md-end gap-2 flex-wrap">
                        <select class="form-select form-select-sm w-auto" id="statusSelect" style="min-width: 150px;">
                            <option value="">Semua Status</option>
                            <option value="Menunggu Verifikasi">Menunggu Verifikasi</option>
                            <option value="Pengecekan Sampel">Pengecekan Sampel</option>
                            <option value="Belum Bayar">Belum Bayar</option>
                            <option value="Belum Lunas">Belum Lunas</option>
                            <option value="Lunas">Lunas</option>
                            <option value="Sedang Diuji">Sedang Diuji</option>
                            <option value="Selesai">Selesai</option>
                        </select>
                        
                        <select class="form-select form-select-sm w-auto" id="sortSelect" style="min-width: 100px;">
                            <option value="desc">Terbaru</option>
                            <option value="asc">Terlama</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Table Card -->
        <div class="card-custom p-0 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="bg-light">
                        <tr>
                            <th>ID Pengajuan</th>
                            <th>Perusahaan / Pemohon</th>
                            <th>Jenis Pengujian</th>
                            <th>Tanggal</th>
                            <th>Status</th>
                            <th class="text-center">Aksi</th>
                        </tr>
                    </thead>
                    <tbody id="submissionsTableBody">
                        <tr>
                            <td colspan="6" class="text-center py-4">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="text-muted mt-2">Memuat data...</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="card-footer bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                <small class="text-muted" id="paginationInfo"></small>
                <nav aria-label="Page navigation">
                    <ul class="pagination mb-0" id="pagination">
                        <!-- Akan diisi JavaScript -->
                    </ul>
                </nav>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS for dropdown -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Custom JS for submissions -->
    <script src="/js/admin/submissions.js"></script>
</body>
</html>