<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    
    <div class="app-wrapper">
        <%- include('partials/sidebar', { page: 'skrd' }) %>

        <main class="main-content">
            <%- include('partials/top-navbar', { pageTitle: 'Manajemen SKRD' }) %>

            <div class="content-body">
                <!-- Alert Message -->
                <div id="alertMessage" class="alert alert-dismissible fade show" style="display: none;"></div>

                <!-- Header Section -->
                <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
                    <div>
                        <h4 class="fw-bold text-dark m-0">Manajemen SKRD</h4>
                        <p class="text-muted small m-0">Monitoring tagihan retribusi dan status pembayaran.</p>
                    </div>
                </div>

                <!-- Stats Cards -->
                <div class="row g-3 mb-4" id="statsCards">
                    <!-- Akan diisi JavaScript -->
                    <div class="col-md-4">
                        <div class="card-custom h-100">
                            <div class="skeleton-loader skeleton-text"></div>
                            <div class="skeleton-loader skeleton-text w-50"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card-custom h-100">
                            <div class="skeleton-loader skeleton-text"></div>
                            <div class="skeleton-loader skeleton-text w-50"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card-custom h-100">
                            <div class="skeleton-loader skeleton-text"></div>
                            <div class="skeleton-loader skeleton-text w-50"></div>
                        </div>
                    </div>
                </div>

                <!-- Filter & Search Section -->
                <div class="card-custom mb-4 border-0 shadow-sm">
                    <div class="d-flex align-items-center bg-light rounded-3 p-1 overflow-auto" style="white-space: nowrap; border: 1px solid #e9ecef;">
                        <!-- Search -->
                        <div class="d-flex align-items-center px-3" style="min-width: 250px; border-right: 1px solid #dee2e6;">
                            <i class="fas fa-search text-muted me-2"></i>
                            <input type="text" class="form-control form-control-sm bg-transparent border-0 shadow-none px-0" id="searchInput" placeholder="Cari ID Pengajuan, Perusahaan...">
                        </div>
                        
                        <!-- Filter Tanggal -->
                        <div class="d-flex align-items-center px-3" style="min-width: 250px; border-right: 1px solid #dee2e6;">
                            <i class="fas fa-calendar-alt text-muted me-2"></i>
                            <input type="date" class="form-control form-control-sm bg-transparent border-0 shadow-none px-0 text-muted" id="startDateFilter" onchange="applyFilter()">
                            <span class="text-muted mx-2">-</span>
                            <input type="date" class="form-control form-control-sm bg-transparent border-0 shadow-none px-0 text-muted" id="endDateFilter" onchange="applyFilter()">
                            <button class="btn btn-sm text-danger p-0 ms-2" onclick="resetDateFilter()" title="Reset">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                        
                        <!-- Filter Status -->
                        <div class="dropdown px-2">
                            <button class="btn btn-sm text-muted dropdown-toggle shadow-none border-0" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="min-width: 160px;">
                                <i class="fas fa-filter me-1"></i> <span id="selectedFilter">Semua Status</span>
                            </button>
                            <ul class="dropdown-menu" id="statusFilter">
                                <li><a class="dropdown-item" href="#" data-status="">Semua Status</a></li>
                                <li><a class="dropdown-item" href="#" data-status="Menunggu Verifikasi">Menunggu Verifikasi</a></li>
                                <li><a class="dropdown-item" href="#" data-status="Pengecekan Sampel">Pengecekan Sampel</a></li>
                                <li><a class="dropdown-item" href="#" data-status="Belum Bayar">Belum Bayar</a></li>
                                <li><a class="dropdown-item" href="#" data-status="Menunggu SKRD Upload">Menunggu SKRD</a></li>
                                <li><a class="dropdown-item" href="#" data-status="Belum Lunas">Belum Lunas</a></li>
                                <li><a class="dropdown-item" href="#" data-status="Lunas">Lunas</a></li>
                                <li><a class="dropdown-item" href="#" data-status="Sedang Diuji">Sedang Diuji</a></li>
                                <li><a class="dropdown-item" href="#" data-status="Selesai">Selesai</a></li>
                                <li><a class="dropdown-item" href="#" data-status="Dibatalkan">Dibatalkan</a></li>
                            </ul>
                        </div>

                        <!-- Export Button -->
                        <div class="ms-auto pe-2">
                            <button class="btn btn-sm btn-success fw-bold" onclick="exportToExcel()">
                                <i class="fas fa-file-excel me-1"></i> Export Excel
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Main Table -->
                <div class="card-custom p-0 overflow-hidden">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr class="text-muted small text-uppercase fw-bold">
                                    <th class="ps-4 py-3">No. Invoice</th>
                                    <th class="py-3">Perusahaan & Layanan</th>
                                    <th class="py-3">Tanggal Terbit</th>
                                    <th class="py-3">Jatuh Tempo</th>
                                    <th class="py-3 text-end">Total Tagihan</th>
                                    <th class="py-3">Status</th>
                                    <th class="py-3 text-end">Sisa</th>
                                    <th class="text-end pe-4 py-3">Aksi</th>
                                </tr>
                            </thead>
                            <tbody id="invoicesTableBody">
                                <!-- Loading State -->
                                <tr id="loadingRow">
                                    <td colspan="8" class="text-center py-5">
                                        <div class="spinner-border text-primary" role="status">
                                            <span class="visually-hidden">Loading...</span>
                                        </div>
                                        <p class="text-muted mt-2">Memuat data...</p>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <div class="card-footer bg-white border-top py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <small class="text-muted" id="paginationInfo"></small>
                        <nav>
                            <ul class="pagination pagination-sm mb-0" id="pagination">
                                <!-- Akan diisi JavaScript -->
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Toast Container -->
    <div id="toastContainer" class="toast-notification"></div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom JS -->
    <script src="/js/admin/skrd.js"></script>
</body>
</html>