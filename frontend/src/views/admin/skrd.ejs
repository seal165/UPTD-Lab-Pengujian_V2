<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    
    <%- include('partials/sidebar', { page: 'skrd' }) %>

    <div class="main-content">
        <!-- Alert Message -->
        <div id="alertMessage" class="alert alert-dismissible fade show" style="display: none;"></div>

        <!-- Header Section -->
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
            <div>
                <h4 class="fw-bold text-dark m-0">Manajemen SKRD</h4>
                <p class="text-muted small m-0">Monitoring tagihan retribusi dan status pembayaran.</p>
            </div>
            <!-- TOMBOL BUAT TAGIHAN BARU DIHAPUS -->
        </div>

        <!-- Stats Cards -->
        <div class="row g-3 mb-4" id="statsCards">
            <!-- Akan diisi JavaScript -->
            <div class="col-md-4">
                <div class="card-custom h-100">
                    <div class="skeleton-loader skeleton-text"></div>
                    <div class="skeleton-loader skeleton-text w-50"></div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card-custom h-100">
                    <div class="skeleton-loader skeleton-text"></div>
                    <div class="skeleton-loader skeleton-text w-50"></div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card-custom h-100">
                    <div class="skeleton-loader skeleton-text"></div>
                    <div class="skeleton-loader skeleton-text w-50"></div>
                </div>
            </div>
        </div>

        <!-- Filter & Search Section -->
        <div class="card-custom mb-4">
            <div class="row g-3 align-items-center">
                <!-- Search -->
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0 text-muted ps-3">
                            <i class="fas fa-search"></i>
                        </span>
                        <input type="text" class="form-control bg-light border-0 shadow-none" id="searchInput" placeholder="Cari ID Pengajuan, Perusahaan, atau PIC...">
                    </div>
                </div>
                
                <!-- Filter Tanggal (di tengah) -->
                <div class="col-md-4">
                    <div class="d-flex gap-2 align-items-center">
                        <div class="flex-fill">
                            <input type="date" class="form-control bg-light border-0 shadow-none" 
                                id="startDateFilter" placeholder="Periode Awal" onchange="applyFilter()">
                        </div>
                        <span class="text-muted">-</span>
                        <div class="flex-fill">
                            <input type="date" class="form-control bg-light border-0 shadow-none" 
                                id="endDateFilter" placeholder="Periode Akhir" onchange="applyFilter()">
                        </div>
                        <button class="btn btn-outline-secondary btn-sm" onclick="resetDateFilter()" title="Reset Tanggal">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                </div>
                
                <!-- Filter Status, Kategori, dan Sort -->
                <div class="col-md-4">
                    <div class="d-flex justify-content-md-end gap-2 flex-wrap">
                        <!-- Filter Status Dropdown -->
                        <div class="dropdown">
                            <button class="btn btn-light text-muted border dropdown-toggle" type="button" 
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-filter me-1"></i> 
                                <span id="selectedFilter">Semua Status</span>
                            </button>
                            <ul class="dropdown-menu" id="statusFilter">
                                <li><a class="dropdown-item" href="#" data-status="">Semua Status</a></li>
                                <li><a class="dropdown-item" href="#" data-status="paid">Lunas</a></li>
                                <li><a class="dropdown-item" href="#" data-status="pending">Belum Bayar</a></li>
                                <li><a class="dropdown-item" href="#" data-status="waiting_verification">Perlu Verifikasi</a></li>
                                <li><a class="dropdown-item" href="#" data-status="overdue">Jatuh Tempo</a></li>
                                <li><a class="dropdown-item" href="#" data-status="cancelled">Dibatalkan</a></li>
                            </ul>
                        </div>

                        <!-- Export Button -->
                        <button class="btn btn-excel fw-bold" onclick="exportToExcel()">
                            <i class="fas fa-file-excel me-1"></i> Export Excel
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Table -->
        <div class="card-custom p-0 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="text-muted small text-uppercase fw-bold">
                            <!-- CHECKBOX DIHAPUS -->
                            <th class="ps-4 py-3">No. Invoice</th>
                            <th class="py-3">Perusahaan & Layanan</th>
                            <th class="py-3">Tanggal Terbit</th>
                            <th class="py-3">Jatuh Tempo</th>
                            <th class="py-3">Total Tagihan</th>
                            <th class="py-3">Status</th>
                            <th class="py-3">Sisa</th>
                            <th class="text-end pe-4 py-3">Aksi</th>
                        </tr>
                    </thead>
                    <tbody id="invoicesTableBody">
                        <!-- Loading State -->
                        <tr id="loadingRow">
                            <td colspan="8" class="text-center py-5">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="text-muted mt-2">Memuat data...</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="card-footer bg-white border-top py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                <small class="text-muted" id="paginationInfo"></small>
                <nav>
                    <ul class="pagination pagination-sm mb-0" id="pagination">
                        <!-- Akan diisi JavaScript -->
                    </ul>
                </nav>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div id="toastContainer" class="toast-notification"></div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ==================== KONFIGURASI ====================
        const API_BASE_URL = 'http://localhost:5000/api';
        const ITEMS_PER_PAGE = 10;
        const LOAD_TIMEOUT = 5000;
        
        // State
        let currentPage = 1;
        let currentStatus = '';
        let searchTerm = '';
        let startDate = '';
        let endDate = '';
        let totalData = 0;
        let allInvoices = [];
        let loadingTimeout;
        let refreshInterval;

        // Cache
        const cache = {
            invoices: { data: null, timestamp: null, params: '' }
        };
        const CACHE_DURATION = 30000;

        // ==================== CEK TOKEN ====================
        function getToken() {
            return localStorage.getItem('admin_token');
        }

        if (!getToken()) {
            window.location.href = '/admin/login';
        }

        // ==================== FUNGSI TOAST ====================
        function showToast(message, type = 'info', duration = 3000) {
            const toastContainer = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `alert alert-${type} alert-dismissible fade show`;
            toast.role = 'alert';
            toast.innerHTML = `
                ${message}
                <button type="button" class="btn-close" onclick="this.parentElement.remove()"></button>
            `;
            toastContainer.appendChild(toast);
            
            setTimeout(() => {
                if (toast.parentElement) {
                    toast.remove();
                }
            }, duration);
        }

        // ==================== FETCH WITH TIMEOUT ====================
        async function fetchWithTimeout(url, options = {}, timeout = LOAD_TIMEOUT) {
            const controller = new AbortController();
            const id = setTimeout(() => controller.abort(), timeout);
            
            try {
                const response = await fetch(url, {
                    ...options,
                    signal: controller.signal
                });
                clearTimeout(id);
                return response;
            } catch (error) {
                clearTimeout(id);
                if (error.name === 'AbortError') {
                    throw new Error('Request timeout');
                }
                throw error;
            }
        }

        // ==================== CACHE ====================
        function getCachedInvoices() {
            const paramsStr = `${currentPage}_${currentStatus}_${searchTerm}_${startDate}_${endDate}`;
            if (cache.invoices.data && 
                cache.invoices.params === paramsStr &&
                (Date.now() - cache.invoices.timestamp < CACHE_DURATION)) {
                return cache.invoices.data;
            }
            return null;
        }

        function setCachedInvoices(data) {
            cache.invoices.data = data;
            cache.invoices.params = `${currentPage}_${currentStatus}_${searchTerm}_${startDate}_${endDate}`;
            cache.invoices.timestamp = Date.now();
        }

        // ==================== LOAD DATA DENGAN FILTER TANGGAL ====================
        async function loadInvoices(showLoadingIndicator = true) {
            const cachedData = getCachedInvoices();
            if (cachedData) {
                allInvoices = cachedData.invoices;
                totalData = cachedData.total;
                updateStats(cachedData.stats);
                
                const loadingRow = document.getElementById('loadingRow');
                if (loadingRow) loadingRow.style.display = 'none';
                
                requestAnimationFrame(() => {
                    updateInvoicesTable(allInvoices);
                    updatePagination();
                });
                return;
            }
            
            if (showLoadingIndicator) showLoading(true);
            
            const loadingRow = document.getElementById('loadingRow');
            if (loadingRow) loadingRow.style.display = '';
            
            loadingTimeout = setTimeout(() => {
                console.log('⚠️ Loading timeout');
            }, 3000);
            
            try {
                const params = new URLSearchParams({
                    page: currentPage,
                    limit: ITEMS_PER_PAGE
                });
                
                if (currentStatus) params.append('status', currentStatus);
                if (searchTerm) params.append('search', searchTerm);
                if (startDate) params.append('start_date', startDate);
                if (endDate) params.append('end_date', endDate);

                const response = await fetchWithTimeout(
                    `${API_BASE_URL}/skrd?${params}`,
                    {
                        headers: {
                            'Authorization': `Bearer ${getToken()}`,
                            'Content-Type': 'application/json'
                        }
                    },
                    5000
                );

                clearTimeout(loadingTimeout);

                if (response.status === 401) {
                    localStorage.removeItem('admin_token');
                    window.location.href = '/admin/login';
                    return;
                }

                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }

                const result = await response.json();

                if (result.success) {
                    setCachedInvoices({
                        invoices: result.data.invoices,
                        total: result.data.total,
                        stats: result.data.stats
                    });
                    
                    allInvoices = result.data.invoices;
                    totalData = result.data.total;
                    
                    updateStats(result.data.stats);
                    
                    setTimeout(() => {
                        updateInvoicesTable(allInvoices);
                        updatePagination();
                    }, 10);
                } else {
                    showAlert(result.message || 'Gagal memuat data', 'danger');
                    if (loadingRow) loadingRow.style.display = 'none';
                }
            } catch (error) {
                clearTimeout(loadingTimeout);
                console.error('Error:', error);
                
                if (loadingRow) loadingRow.style.display = 'none';
                
                if (error.message.includes('timeout')) {
                    showAlert('Koneksi lambat, silakan coba lagi', 'warning');
                } else {
                    showAlert('Gagal terhubung ke server', 'danger');
                }
            } finally {
                if (showLoadingIndicator) showLoading(false);
            }
        }

        // ==================== UPDATE STATS ====================
        function updateStats(stats) {
            const statsHtml = `
                <div class="col-md-4">
                    <div class="card-custom h-100 flex-row align-items-center justify-content-between">
                        <div>
                            <p class="text-muted mb-1 small fw-bold text-uppercase">Total Piutang</p>
                            <h3 class="fw-bold m-0 text-dark">${stats.totalReceivable || 'Rp 0'}</h3>
                            <div class="mt-2 d-flex gap-2">
                                <span class="badge badge-soft-danger">
                                    <i class="fas fa-times-circle me-1"></i>${stats.pendingCount || 0} Belum Bayar
                                </span>
                                <span class="badge badge-soft-warning">
                                    <i class="fas fa-hourglass-half me-1"></i>${stats.partialCount || 0} Belum Lunas
                                </span>
                            </div>
                        </div>
                        <div class="bg-danger-subtle p-3 rounded-circle text-danger">
                            <i class="fas fa-wallet fa-lg"></i>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card-custom h-100 flex-row align-items-center justify-content-between">
                        <div>
                            <p class="text-muted mb-1 small fw-bold text-uppercase">Perlu Verifikasi</p>
                            <h3 class="fw-bold m-0 text-dark">${stats.waitingVerification || 0}</h3>
                            <div class="mt-2">
                                <span class="badge badge-soft-primary">
                                    <i class="fas fa-exclamation-circle me-1"></i>Menunggu Verifikasi
                                </span>
                            </div>
                        </div>
                        <div class="bg-primary-subtle p-3 rounded-circle text-primary">
                            <i class="fas fa-file-invoice-dollar fa-lg"></i>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card-custom h-100 flex-row align-items-center justify-content-between">
                        <div>
                            <p class="text-muted mb-1 small fw-bold text-uppercase">Pendapatan Bulan Ini</p>
                            <h3 class="fw-bold m-0 text-dark">${stats.monthlyIncome || 'Rp 0'}</h3>
                            <div class="mt-2">
                                <span class="badge badge-soft-success">
                                    <i class="fas fa-check-circle me-1"></i>${stats.paidCount || 0} Transaksi Lunas
                                </span>
                            </div>
                        </div>
                        <div class="bg-success-subtle p-3 rounded-circle text-success">
                            <i class="fas fa-coins fa-lg"></i>
                        </div>
                    </div>
                </div>
            `;
            
            document.getElementById('statsCards').innerHTML = statsHtml;
        }

        // ==================== UPDATE TABLE (HAPUS KOLOM METODE) ====================
        function updateInvoicesTable(invoices) {
            const loadingRow = document.getElementById('loadingRow');
            if (loadingRow) {
                loadingRow.style.display = 'none';
            }
            
            const tbody = document.getElementById('invoicesTableBody');
            
            if (!invoices || invoices.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="8" class="text-center py-5">
                            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                            <p class="text-muted">Tidak ada data tagihan</p>
                        </td>
                    </tr>
                `;
                return;
            }

            let html = '';
            invoices.forEach(inv => {
                let statusClass = 'badge-soft-secondary';
                let statusText = '';
                let sisa = inv.remaining_amount || 0;
                let paidAmount = inv.paid_amount || 0;
                let totalAmount = inv.total_amount || 0;
                
                // Tentukan status berdasarkan payment_status
                switch(inv.status) {
                    case 'paid':
                        statusClass = 'badge-soft-success';
                        statusText = 'Lunas';
                        break;
                    case 'partial':
                        statusClass = 'badge-soft-warning';
                        statusText = 'Belum Lunas';
                        break;
                    case 'pending':
                        statusClass = 'badge-soft-danger';
                        statusText = 'Belum Bayar';
                        break;
                    case 'waiting_verification':
                        statusClass = 'badge-soft-primary';
                        statusText = 'Cek Bukti';
                        break;
                    case 'overdue':
                        statusClass = 'badge-soft-danger';
                        statusText = 'Jatuh Tempo';
                        break;
                    case 'cancelled':
                        statusClass = 'badge-soft-secondary';
                        statusText = 'Dibatalkan';
                        break;
                    default:
                        statusClass = 'badge-soft-secondary';
                        statusText = inv.status;
                }
                
                // Hitung progress pembayaran untuk partial
                let progressHtml = '';
                if (inv.status === 'partial') {
                    const progress = Math.round((paidAmount / totalAmount) * 100);
                    progressHtml = `
                        <div class="progress mt-1" style="height: 4px;">
                            <div class="progress-bar bg-warning" style="width: ${progress}%"></div>
                        </div>
                        <small class="text-muted">Dibayar: ${formatRupiah(paidAmount)}</small>
                    `;
                }
                
                html += `
                    <tr>
                        <td class="ps-4">
                            <span class="fw-bold text-primary">#${inv.invoice_number || '-'}</span>
                            <div class="small text-muted">SKRD: ${inv.skrd_number || '-'}</div>
                        </td>
                        <td>
                            <div class="fw-bold text-dark">${inv.company_name || '-'}</div>
                            <small class="text-muted">${inv.service_description || '-'}</small>
                        </td>
                        <td class="text-muted small">${formatDate(inv.issue_date)}</td>
                        <td class="text-muted small ${isOverdue(inv.due_date, inv.status) ? 'text-danger fw-bold' : ''}">
                            ${formatDate(inv.due_date)}
                            ${isOverdue(inv.due_date, inv.status) ? '<i class="fas fa-exclamation-circle ms-1 text-danger"></i>' : ''}
                        </td>
                        <td class="fw-bold text-dark">${formatRupiah(totalAmount)}</td>
                        <td>
                            <span class="badge ${statusClass} px-3 py-2">${statusText}</span>
                            ${progressHtml}
                        </td>
                        <td class="fw-bold ${sisa > 0 ? 'text-danger' : 'text-success'}">${formatRupiah(sisa)}</td>
                        <td class="text-end pe-4">
                            <a href="/admin/skrd/${inv.id}" class="btn btn-sm btn-light">Detail</a>
                        </td>
                    </tr>
                `;
            });

            tbody.innerHTML = html;
        }
                
        // ==================== HELPER FUNCTIONS ====================
        function formatDate(dateString) {
            if (!dateString) return '-';
            const date = new Date(dateString);
            const months = ['Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agu', 'Sep', 'Okt', 'Nov', 'Des'];
            return `${date.getDate()} ${months[date.getMonth()]} ${date.getFullYear()}`;
        }

        function formatRupiah(number) {
            return new Intl.NumberFormat('id-ID', {
                style: 'currency',
                currency: 'IDR',
                minimumFractionDigits: 0
            }).format(number || 0);
        }

        function isOverdue(dueDate, status) {
            if (!dueDate || status === 'paid' || status === 'cancelled') return false;
            return new Date(dueDate) < new Date();
        }

        function getStatusText(status) {
            const texts = {
                'paid': 'Lunas',
                'pending': 'Belum Bayar',
                'waiting_verification': 'Cek Bukti',
                'overdue': 'Jatuh Tempo',
                'cancelled': 'Dibatalkan'
            };
            return texts[status] || status;
        }

        // ==================== FILTER TANGGAL ====================
        function applyFilter() {
            startDate = document.getElementById('startDateFilter')?.value || '';
            endDate = document.getElementById('endDateFilter')?.value || '';
            
            // Validasi tanggal
            if (startDate && endDate && new Date(startDate) > new Date(endDate)) {
                showAlert('Tanggal akhir harus setelah tanggal awal', 'warning');
                return;
            }
            
            currentPage = 1;
            loadInvoices(true);
        }

        function resetDateFilter() {
            document.getElementById('startDateFilter').value = '';
            document.getElementById('endDateFilter').value = '';
            startDate = '';
            endDate = '';
            currentPage = 1;
            loadInvoices(true);
        }

        // ==================== FILTER HANDLERS ====================
        function setupFilters() {
            let searchTimeout;
            const searchInput = document.getElementById('searchInput');
            if (searchInput) {
                searchInput.addEventListener('input', (e) => {
                    clearTimeout(searchTimeout);
                    searchTimeout = setTimeout(() => {
                        searchTerm = e.target.value;
                        currentPage = 1;
                        loadInvoices(true);
                    }, 500);
                });
            }

            document.querySelectorAll('#statusFilter .dropdown-item').forEach(item => {
                item.addEventListener('click', (e) => {
                    e.preventDefault();
                    currentStatus = e.target.dataset.status;
                    document.getElementById('selectedFilter').textContent = e.target.textContent;
                    currentPage = 1;
                    loadInvoices(true);
                    updateActiveFilter(currentStatus);
                });
            });

            document.querySelectorAll('.filter-badge').forEach(badge => {
                badge.addEventListener('click', () => {
                    const status = badge.dataset.status;
                    currentStatus = status;
                    currentPage = 1;
                    
                    const statusText = status ? badge.textContent.trim() : 'Semua Status';
                    document.getElementById('selectedFilter').textContent = statusText;
                    
                    updateActiveFilter(status);
                    loadInvoices(true);
                });
            });
        }

        function updateActiveFilter(activeStatus) {
            document.querySelectorAll('.filter-badge').forEach(badge => {
                if (badge.dataset.status === activeStatus) {
                    badge.classList.add('active', 'bg-primary', 'text-white');
                } else {
                    badge.classList.remove('active', 'bg-primary', 'text-white');
                }
            });
        }

        // ==================== PAGINATION ====================
        function updatePagination() {
            const totalPages = Math.ceil(totalData / ITEMS_PER_PAGE);
            const pagination = document.getElementById('pagination');
            
            if (!pagination) return;
            
            if (totalPages <= 1) {
                pagination.innerHTML = '';
                document.getElementById('paginationInfo').innerHTML = 
                    `Menampilkan ${totalData} data`;
                return;
            }

            let paginationHtml = '';
            
            paginationHtml += `
                <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                    <a class="page-link rounded-2 me-1" href="#" onclick="changePage(${currentPage - 1})">
                        Prev
                    </a>
                </li>
            `;

            for (let i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) {
                    paginationHtml += `
                        <li class="page-item ${currentPage === i ? 'active' : ''}">
                            <a class="page-link rounded-2 me-1" href="#" onclick="changePage(${i})">${i}</a>
                        </li>
                    `;
                } else if (i === currentPage - 3 || i === currentPage + 3) {
                    paginationHtml += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
                }
            }

            paginationHtml += `
                <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                    <a class="page-link rounded-2" href="#" onclick="changePage(${currentPage + 1})">
                        Next
                    </a>
                </li>
            `;

            pagination.innerHTML = paginationHtml;
            
            const start = ((currentPage - 1) * ITEMS_PER_PAGE) + 1;
            const end = Math.min(currentPage * ITEMS_PER_PAGE, totalData);
            document.getElementById('paginationInfo').innerHTML = 
                `Menampilkan ${start}-${end} dari ${totalData} data`;
        }

        function changePage(page) {
            currentPage = page;
            loadInvoices(true);
        }

        // ==================== EXPORT EXCEL (DENGAN FILTER TANGGAL) ====================
        async function exportToExcel() {
            if (!allInvoices || allInvoices.length === 0) {
                showAlert('Tidak ada data untuk diexport', 'warning');
                return;
            }

            try {
                showToast('Menyiapkan file Excel...', 'info');
                
                // Ambil semua data (tanpa pagination) dengan filter yang sama
                const params = new URLSearchParams({
                    limit: 1000 // Ambil banyak data
                });
                
                if (currentStatus) params.append('status', currentStatus);
                if (searchTerm) params.append('search', searchTerm);
                if (startDate) params.append('start_date', startDate);
                if (endDate) params.append('end_date', endDate);

                const response = await fetchWithTimeout(
                    `${API_BASE_URL}/skrd?${params}`,
                    {
                        headers: {
                            'Authorization': `Bearer ${getToken()}`,
                            'Content-Type': 'application/json'
                        }
                    },
                    10000 // Timeout lebih lama untuk export
                );

                if (!response.ok) {
                    throw new Error('Gagal mengambil data');
                }

                const result = await response.json();
                
                if (!result.success || !result.data.invoices) {
                    throw new Error('Data tidak ditemukan');
                }

                const allData = result.data.invoices;

                const headers = [
                    'No. Invoice', 'SKRD', 'Perusahaan', 'Layanan', 'Tanggal Terbit',
                    'Jatuh Tempo', 'Total Tagihan', 'Status', 'Sisa'
                ];
                
                const rows = allData.map(inv => {
                    let sisa = 0;
                    if (inv.status !== 'paid' && inv.status !== 'cancelled') {
                        sisa = inv.payment_method === 'cicil_2x' ? inv.total_amount / 2 : inv.total_amount;
                    }
                    
                    return [
                        inv.invoice_number,
                        inv.skrd_number || '-',
                        inv.company_name || '-',
                        inv.service_description || '-',
                        formatDate(inv.issue_date),
                        formatDate(inv.due_date),
                        inv.total_amount,
                        getStatusText(inv.status),
                        sisa
                    ];
                });

                // Buat CSV
                const csvContent = [
                    headers.join(','),
                    ...rows.map(row => row.map(cell => `"${cell}"`).join(','))
                ].join('\n');

                // Download file
                const blob = new Blob(['\uFEFF' + csvContent], { type: 'text/csv;charset=utf-8;' });
                const url = window.URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                
                // Nama file dengan filter tanggal jika ada
                let filename = `skrd_${new Date().toISOString().split('T')[0]}`;
                if (startDate && endDate) {
                    filename += `_${startDate}_${endDate}`;
                } else if (startDate) {
                    filename += `_dari_${startDate}`;
                } else if (endDate) {
                    filename += `_sampai_${endDate}`;
                }
                filename += '.csv';
                
                a.download = filename;
                a.click();
                window.URL.revokeObjectURL(url);
                
                showToast(`Export berhasil: ${rows.length} data`, 'success');
                
            } catch (error) {
                console.error('Export error:', error);
                showAlert('Gagal export data: ' + error.message, 'danger');
            }
        }

        // ==================== UI CONTROLS ====================
        function showLoading(show) {
            const overlay = document.getElementById('loadingOverlay');
            if (overlay) {
                overlay.style.display = show ? 'flex' : 'none';
            }
        }

        function showAlert(message, type) {
            const alertDiv = document.getElementById('alertMessage');
            alertDiv.style.display = 'block';
            alertDiv.className = `alert alert-${type} alert-dismissible fade show`;
            alertDiv.innerHTML = `
                ${message}
                <button type="button" class="btn-close" onclick="this.parentElement.style.display='none'"></button>
            `;
            
            setTimeout(() => {
                alertDiv.style.display = 'none';
            }, 5000);
        }

        // ==================== INITIALIZE ====================
        document.addEventListener('DOMContentLoaded', () => {
            setupFilters();
            loadInvoices(true);
            
            refreshInterval = setInterval(() => loadInvoices(false), 60000);
            
            window.addEventListener('beforeunload', () => {
                if (refreshInterval) clearInterval(refreshInterval);
                if (loadingTimeout) clearTimeout(loadingTimeout);
            });
        });
    </script>
</body>
</html>