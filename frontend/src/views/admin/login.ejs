<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Login - UPTD Lab</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin-style.css">
</head>
<body class="login-body">

    <div class="login-container">
        <div class="text-center mb-4">
            <div class="flask-icon mb-3">
                <i class="fas fa-flask"></i>
            </div>
            <h4 class="fw-bold text-white">UPTD Lab Manager</h4>
            <p class="text-white-50 mb-0">Construction Material Testing Laboratory</p>
        </div>

        <div class="login-card">
            <h5 class="fw-bold mb-2">Admin Login</h5>
            <p class="text-muted small mb-4">Masukkan kredensial Anda untuk mengakses dashboard</p>
            
            <!-- Alert untuk menampilkan pesan error/sukses -->
            <div id="alertMessage" style="display: none;"></div>
            
            <!-- Form Login -->
            <form id="loginForm">
                <div class="mb-3">
                    <label class="form-label small fw-bold">Email</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="far fa-envelope text-muted"></i>
                        </span>
                        <input type="email" 
                               class="form-control border-start-0" 
                               id="email" 
                               name="email" 
                               placeholder="admin@uptd.gov.id" 
                               required>
                    </div>
                </div>
                
                <div class="mb-3">
                    <label class="form-label small fw-bold">Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="fas fa-lock text-muted"></i>
                        </span>
                        <input type="password" 
                               class="form-control border-start-0" 
                               id="password" 
                               name="password" 
                               placeholder="••••••••" 
                               required>
                        <button class="btn btn-light border" 
                                type="button" 
                                onclick="togglePassword()">
                            <i class="far fa-eye" id="togglePasswordIcon"></i>
                        </button>
                    </div>
                </div>
                
                <div class="d-flex justify-content-between mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="remember">
                        <label class="form-check-label small" for="remember">
                            Ingat saya
                        </label>
                    </div>
                    <a href="#" class="small text-decoration-none" onclick="showForgotPassword(event)">
                        Lupa password?
                    </a>
                </div>
                
                <button type="submit" class="btn btn-dark w-100 py-2" id="loginButton">
                    <span id="buttonText">Login sebagai Administrator</span>
                    <span id="buttonSpinner" style="display: none;">
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        Memproses...
                    </span>
                </button>
            </form>
            
            <!-- Informasi Login -->
            <div class="login-info mt-4 pt-3 border-top">
                <p class="small text-muted mb-1">
                    <i class="fas fa-shield-alt me-1"></i> 
                    Gunakan akun administrator yang telah terdaftar
                </p>
                <p class="small text-muted mb-0">
                    <i class="fas fa-database me-1"></i> 
                    Terhubung dengan database UPTD Lab
                </p>
            </div>
        </div>
        
        <div class="mt-4 text-center small text-white-50">
            <i class="fas fa-shield-alt me-1"></i> Restricted Access. Authorized Personnel Only.<br>
            © 2026 UPTD Construction Material Testing Lab.
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Login JavaScript -->
    <script src="/js/admin/login.js"></script>
</body>
</html>