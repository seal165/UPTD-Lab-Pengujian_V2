        // Helper function untuk generate rows items
        function generateInvoiceItems(data) {
            const items = data.items || [];
            const testType = data.test_type || 'Pengujian';
            const totalAmount = data.total_amount || 0;
            const hargaSatuan = Math.round(totalAmount / 1.11);
            
            if (items.length === 0) {
                return `
                    <tr>
                        <td class="text-center">1</td>
                        <td>${testType}</td>
                        <td class="text-center">1 sampel</td>
                        <td class="text-right">${formatRupiah(hargaSatuan).replace('Rp', 'Rp ')}</td>
                        <td class="text-right">${formatRupiah(hargaSatuan).replace('Rp', 'Rp ')}</td>
                    </tr>
                `;
            } else {
                let rows = '';
                items.forEach((item, index) => {
                    const description = item.description || item.service_name || item.name || 'Pengujian';
                    const quantity = item.quantity || 1;
                    const unit = item.unit || 'sampel';
                    const price = item.price || item.unit_price || 0;
                    const subtotal = item.subtotal || (quantity * price);
                    
                    rows += `
                        <tr>
                            <td class="text-center">${index + 1}</td>
                            <td>${description}</td>
                            <td class="text-center">${quantity} ${unit}</td>
                            <td class="text-right">${formatRupiah(price).replace('Rp', 'Rp ')}</td>
                            <td class="text-right">${formatRupiah(subtotal).replace('Rp', 'Rp ')}</td>
                        </tr>
                    `;
                });
                return rows;
            }
        }

