        <!-- TAMBAHKAN CSS UNTUK POP-UP (MODAL) DI SINI -->
        <style>
            .step-card {
                cursor: pointer;
                transition: transform 0.3s ease, box-shadow 0.3s ease;
            }
            .step-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            }
            
            /* Modal Styles */
            .modal-overlay {
                display: none; 
                position: fixed; 
                z-index: 1000; 
                left: 0;
                top: 0;
                width: 100%; 
                height: 100%; 
                background-color: rgba(0, 0, 0, 0.5); 
                backdrop-filter: blur(3px);
            }
            
            .modal-content {
                background-color: #fff;
                margin: 10% auto; 
                padding: 30px;
                border-radius: 12px;
                width: 90%;
                max-width: 600px;
                box-shadow: 0 15px 30px rgba(0,0,0,0.2);
                position: relative;
                animation: modalFadeIn 0.3s ease;
            }

            @keyframes modalFadeIn {
                from { opacity: 0; transform: translateY(-20px); }
                to { opacity: 1; transform: translateY(0); }
            }
            
            .close-btn {
                color: #aaa;
                position: absolute;
                top: 15px;
                right: 20px;
                font-size: 28px;
                font-weight: bold;
                cursor: pointer;
            }
            
            .close-btn:hover,
            .close-btn:focus {
                color: #333;
                text-decoration: none;
            }

            .modal-title {
                color: #047857; /* Warna primary menyesuaikan */
                margin-top: 0;
                margin-bottom: 15px;
                border-bottom: 2px solid #e2e8f0;
                padding-bottom: 10px;
            }

            .modal-body ol {
                padding-left: 20px;
                margin-top: 10px;
            }

            .modal-body li {
                margin-bottom: 8px;
                line-height: 1.5;
                color: #475569;
            }
            .modal-body p {
                color: #475569;
            }
        </style>

        <section id="layanan" class="section bg-light">
            <div class="container">
                <div class="text-center">
                    <span class="section-subtitle">Layanan Pengujian</span>
                    <h2 class="section-title">Ruang Lingkup & Tarif</h2>
                </div>

                <div class="steps-container">
                    <!-- Tambahkan onclick pada masing-masing card -->
                    <div class="step-card" onclick="openModal('modal-1')">
                        <div class="step-icon-box"><i class="fas fa-file-alt"></i></div>
                        <div>
                            <h5>1. Permohonan</h5>
                            <p>Isi form & bawa sampel</p>
                        </div>
                    </div>
                    <div class="step-card" onclick="openModal('modal-2')">
                        <div class="step-icon-box"><i class="fas fa-clipboard-check"></i></div>
                        <div>
                            <h5>2. Pengecekan</h5>
                            <p>Pengecekan sampel</p>
                        </div>
                    </div>
                    <div class="step-card" onclick="openModal('modal-3')">
                        <div class="step-icon-box"><i class="fas fa-search"></i></div>
                        <div>
                            <h5>3. Kaji Ulang</h5>
                            <p>Cek kondisi sampel</p>
                        </div>
                    </div>
                    <div class="step-card" onclick="openModal('modal-4')">
                        <div class="step-icon-box"><i class="fas fa-wallet"></i></div>
                        <div>
                            <h5>4. Bayar</h5>
                            <p>Retribusi via Bank/QRIS</p>
                        </div>
                    </div>
                    <div class="step-card" onclick="openModal('modal-5')">
                        <div class="step-icon-box"><i class="fas fa-flask"></i></div>
                        <div>
                            <h5>5. Pengujian</h5>
                            <p>Analisa Lab/Lapangan</p>
                        </div>
                    </div>
                    <div class="step-card" onclick="openModal('modal-6')">
                        <div class="step-icon-box"><i class="fas fa-certificate"></i></div>
                        <div>
                            <h5>6. Selesai</h5>
                            <p>Ambil Laporan (LHU)</p>
                        </div>
                    </div>
                </div>

                <!-- ... (Bagian Cards Grid Akreditasi & Pricing Table tetap sama seperti kode Anda) ... -->

            </div>
        </section>

        <!-- ... (Bagian Profil tetap sama seperti kode Anda) ... -->

        <!-- KUMPULAN HTML POP-UP (MODAL) -->
        
        <!-- Modal 1: Permohonan -->
        <div id="modal-1" class="modal-overlay">
            <div class="modal-content">
                <span class="close-btn" onclick="closeModal('modal-1')">&times;</span>
                <h3 class="modal-title"><i class="fas fa-file-alt"></i> 1. Permohonan</h3>
                <div class="modal-body">
                    <p><strong>Deskripsi:</strong> Proses awal pengajuan layanan pengujian oleh pemohon.</p>
                    <p><strong>Alur:</strong></p>
                    <ol>
                        <li>Melakukan registrasi akun dan masuk (<em>login</em>) ke dalam sistem.</li>
                        <li>Mengakses halaman <strong>Pengajuan Pengujian</strong>.</li>
                        <li>Memilih kategori serta jenis pengujian, kemudian memasukkan jumlah sampel yang akan diuji.</li>
                        <li>Melengkapi formulir pengajuan yang tersedia pada halaman sistem.</li>
                        <li>Mengunggah dokumen kelengkapan, meliputi: surat permohonan resmi dari instansi, hasil pindai (<em>scan</em>) Kartu Tanda Penduduk (KTP) yang sesuai dengan nama pemohon, serta dokumen lampiran pendukung lainnya.</li>
                        <li>Menekan tombol <strong>Kirim</strong> untuk memproses pengajuan ke dalam sistem.</li>
                    </ol>
                </div>
            </div>
        </div>

        <!-- Modal 2: Pengecekan -->
        <div id="modal-2" class="modal-overlay">
            <div class="modal-content">
                <span class="close-btn" onclick="closeModal('modal-2')">&times;</span>
                <h3 class="modal-title"><i class="fas fa-clipboard-check"></i> 2. Pengecekan Sampel</h3>
                <div class="modal-body">
                    <p><strong>Deskripsi:</strong> Penyerahan dan identifikasi awal sampel pengujian.</p>
                    <p><strong>Alur:</strong></p>
                    <ol>
                        <li>Sampel uji diserahkan secara langsung atau diantarkan ke laboratorium untuk proses identifikasi dan pencatatan awal oleh petugas.</li>
                    </ol>
                </div>
            </div>
        </div>

        <!-- Modal 3: Kaji Ulang -->
        <div id="modal-3" class="modal-overlay">
            <div class="modal-content">
                <span class="close-btn" onclick="closeModal('modal-3')">&times;</span>
                <h3 class="modal-title"><i class="fas fa-search"></i> 3. Kaji Ulang</h3>
                <div class="modal-body">
                    <p><strong>Deskripsi:</strong> Evaluasi teknis terhadap sampel yang diserahkan.</p>
                    <p><strong>Alur:</strong></p>
                    <ol>
                        <li>Petugas melakukan peninjauan dan evaluasi kondisi sampel untuk menentukan kelayakan uji berdasarkan standar operasional prosedur (SOP) yang berlaku.</li>
                    </ol>
                </div>
            </div>
        </div>

        <!-- Modal 4: Bayar -->
        <div id="modal-4" class="modal-overlay">
            <div class="modal-content">
                <span class="close-btn" onclick="closeModal('modal-4')">&times;</span>
                <h3 class="modal-title"><i class="fas fa-wallet"></i> 4. Pembayaran</h3>
                <div class="modal-body">
                    <p><strong>Deskripsi:</strong> Proses penyelesaian administrasi dan retribusi pengujian.</p>
                    <p><strong>Alur:</strong></p>
                    <ol>
                        <li>Apabila sampel dinyatakan layak uji, pemohon dapat mengakses halaman <strong>Transaksi</strong>.</li>
                        <li>Menunggu administrator mengunggah dokumen Surat Ketetapan Retribusi Daerah (SKRD).</li>
                        <li>Melakukan pembayaran retribusi sesuai dengan instruksi dan nominal yang tertera pada dokumen SKRD, kemudian mengunggah bukti pembayaran ke dalam sistem.</li>
                        <li>Administrator yang berwenang akan melakukan verifikasi dan validasi terhadap bukti pembayaran tersebut.</li>
                    </ol>
                </div>
            </div>
        </div>

        <!-- Modal 5: Pengujian -->
        <div id="modal-5" class="modal-overlay">
            <div class="modal-content">
                <span class="close-btn" onclick="closeModal('modal-5')">&times;</span>
                <h3 class="modal-title"><i class="fas fa-flask"></i> 5. Pengujian</h3>
                <div class="modal-body">
                    <p><strong>Deskripsi:</strong> Pelaksanaan analisa laboratorium atau lapangan.</p>
                    <p><strong>Alur:</strong></p>
                    <ol>
                        <li>Setelah sampel dinyatakan memenuhi kriteria kaji ulang dan proses administrasi pembayaran selesai, tim teknis akan melaksanakan proses pengujian sampel baik di laboratorium maupun di lapangan.</li>
                    </ol>
                </div>
            </div>
        </div>

        <!-- Modal 6: Selesai -->
        <div id="modal-6" class="modal-overlay">
            <div class="modal-content">
                <span class="close-btn" onclick="closeModal('modal-6')">&times;</span>
                <h3 class="modal-title"><i class="fas fa-certificate"></i> 6. Selesai</h3>
                <div class="modal-body">
                    <p><strong>Deskripsi:</strong> Pengambilan hasil dan penyelesaian prosedur layanan.</p>
                    <p><strong>Alur:</strong></p>
                    <ol>
                        <li>Pemohon mengakses kembali halaman <strong>Pengujian</strong> pada sistem.</li>
                        <li>Mengisi kuesioner evaluasi layanan (Indeks Kepuasan Masyarakat).</li>
                        <li>Mengunduh dokumen Laporan Hasil Uji (LHU) atau sertifikat pengujian elektronik yang telah dilegalisasi.</li>
                    </ol>
                </div>
            </div>
        </div>

        <!-- SCRIPT UNTUK MENJALANKAN POP-UP (MODAL) -->
        <script>
            // Fungsi untuk membuka modal
            function openModal(modalId) {
                document.getElementById(modalId).style.display = "block";
                document.body.style.overflow = "hidden"; // Mencegah scrolling pada background
            }

            // Fungsi untuk menutup modal
            function closeModal(modalId) {
                document.getElementById(modalId).style.display = "none";
                document.body.style.overflow = "auto"; // Mengembalikan scrolling
            }

            // Menutup modal jika area luar (overlay) di-klik
            window.onclick = function(event) {
                if (event.target.classList.contains('modal-overlay')) {
                    event.target.style.display = "none";
                    document.body.style.overflow = "auto";
                }
            }
        </script>

