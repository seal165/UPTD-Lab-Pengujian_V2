<% 
const title = locals.title || 'Transaction List - UPTD Lab';
const currentPage = locals.currentPage || 'transaction';
const pageTitle = locals.pageTitle || 'Transaction List';
const user = locals.user || {};
const notificationCount = locals.notificationCount || 0;

// Data transaksi dari controller
const transactions = locals.transactions || [];
%>
<%- include('partials/header', { title }) %>
<link rel="stylesheet" href="/css/user/transaction.css">
<%- include('partials/sidebar', { currentPage, user }) %>

<main class="main-content">
    <%- include('partials/top-navbar', { pageTitle, user, notificationCount }) %>
    
    <div class="transaction-container">
        <div class="transaction-header">
            <h2><i class="fas fa-exchange-alt"></i> Billing & Payments</h2>
        </div>
        
        <!-- Data dari backend disimpan di atribut data -->
        <div id="transaction-data" 
             data-transactions='<%- JSON.stringify(transactions).replace(/'/g, "\\'") %>'
             style="display: none;"></div>
        
        <div class="transaction-stats" id="transactionStats">
            <!-- Akan diisi JavaScript -->
        </div>
        
        <div class="transaction-controls">
            <div class="filter-controls">
                <input type="text" id="searchInput" placeholder="Cari ID Transaksi atau Layanan...">
                <select id="statusFilter" class="filter-select">
                    <option value="all">Semua Status</option>
                    <option value="Lunas">Lunas</option>
                    <option value="Belum Lunas">Belum Lunas</option>
                    <option value="Belum Bayar">Belum Bayar</option>
                </select>
            </div>
            <button class="export-btn" id="exportBtn">
                <i class="fas fa-file-export"></i> Export Data
            </button>
        </div>
        
        <div class="transaction-table-container">
            <table class="transaction-table">
                <thead>
                    <tr>
                        <th>No. Invoice</th>
                        <th>Layanan</th>
                        <th>Total</th>
                        <th>Dibayar</th>
                        <th>Sisa</th>
                        <th>Status</th>
                        <th>Tanggal</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody id="transactionTableBody">
                    <!-- Akan diisi JavaScript -->
                </tbody>
            </table>
        </div>
    </div>
    
    <%- include('partials/footer') %>
</main>

<script src="/js/user/transaction.js"></script>